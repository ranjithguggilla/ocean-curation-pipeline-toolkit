<?xml version="1.0" encoding="UTF-8"?>
<gmi:MI_Metadata
    xmlns:gmi="http://www.isotc211.org/2005/gmi"
    xmlns:gmd="http://www.isotc211.org/2005/gmd"
    xmlns:gco="http://www.isotc211.org/2005/gco"
    xmlns:gml="http://www.opengis.net/gml/3.2"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.isotc211.org/2005/gmi https://schemas.opengis.net/iso/19139/20070417/gmi/gmi.xsd">

  <!-- ================================================================== -->
  <!-- File Identifier                                                     -->
  <!-- ================================================================== -->
  <gmd:fileIdentifier>
    <gco:CharacterString>{{ file_identifier }}</gco:CharacterString>
  </gmd:fileIdentifier>

  <gmd:language>
    <gco:CharacterString>{{ language }}</gco:CharacterString>
  </gmd:language>

  <gmd:characterSet>
    <gmd:MD_CharacterSetCode
        codeList="http://www.isotc211.org/2005/resources/Codelist/gmxCodelists.xml#MD_CharacterSetCode"
        codeListValue="{{ character_set }}">{{ character_set }}</gmd:MD_CharacterSetCode>
  </gmd:characterSet>

  <gmd:hierarchyLevel>
    <gmd:MD_ScopeCode
        codeList="http://www.isotc211.org/2005/resources/Codelist/gmxCodelists.xml#MD_ScopeCode"
        codeListValue="{{ hierarchy_level }}">{{ hierarchy_level }}</gmd:MD_ScopeCode>
  </gmd:hierarchyLevel>

  <!-- ================================================================== -->
  <!-- Contact: Principal Investigator                                     -->
  <!-- ================================================================== -->
  <gmd:contact>
    <gmd:CI_ResponsibleParty>
      <gmd:individualName>
        <gco:CharacterString>{{ contact_name }}</gco:CharacterString>
      </gmd:individualName>
      <gmd:organisationName>
        <gco:CharacterString>{{ contact_org }}</gco:CharacterString>
      </gmd:organisationName>
      <gmd:contactInfo>
        <gmd:CI_Contact>
          <gmd:address>
            <gmd:CI_Address>
              <gmd:electronicMailAddress>
                <gco:CharacterString>{{ contact_email }}</gco:CharacterString>
              </gmd:electronicMailAddress>
            </gmd:CI_Address>
          </gmd:address>
        </gmd:CI_Contact>
      </gmd:contactInfo>
      <gmd:role>
        <gmd:CI_RoleCode
            codeList="http://www.isotc211.org/2005/resources/Codelist/gmxCodelists.xml#CI_RoleCode"
            codeListValue="{{ contact_role }}">{{ contact_role }}</gmd:CI_RoleCode>
      </gmd:role>
    </gmd:CI_ResponsibleParty>
  </gmd:contact>

  <!-- ================================================================== -->
  <!-- Date Stamp                                                          -->
  <!-- ================================================================== -->
  <gmd:dateStamp>
    <gco:Date>{{ date_stamp }}</gco:Date>
  </gmd:dateStamp>

  <!-- ================================================================== -->
  <!-- Metadata Standard                                                   -->
  <!-- ================================================================== -->
  <gmd:metadataStandardName>
    <gco:CharacterString>{{ metadata_standard_name }}</gco:CharacterString>
  </gmd:metadataStandardName>
  <gmd:metadataStandardVersion>
    <gco:CharacterString>{{ metadata_standard_version }}</gco:CharacterString>
  </gmd:metadataStandardVersion>

  <!-- ================================================================== -->
  <!-- Identification Info                                                 -->
  <!-- ================================================================== -->
  <gmd:identificationInfo>
    <gmd:MD_DataIdentification>
      <gmd:citation>
        <gmd:CI_Citation>
          <gmd:title>
            <gco:CharacterString>{{ title }}</gco:CharacterString>
          </gmd:title>
          <gmd:date>
            <gmd:CI_Date>
              <gmd:date>
                <gco:Date>{{ date_stamp }}</gco:Date>
              </gmd:date>
              <gmd:dateType>
                <gmd:CI_DateTypeCode
                    codeList="http://www.isotc211.org/2005/resources/Codelist/gmxCodelists.xml#CI_DateTypeCode"
                    codeListValue="publication">publication</gmd:CI_DateTypeCode>
              </gmd:dateType>
            </gmd:CI_Date>
          </gmd:date>
          {% if doi %}
          <gmd:identifier>
            <gmd:MD_Identifier>
              <gmd:code>
                <gco:CharacterString>doi:{{ doi }}</gco:CharacterString>
              </gmd:code>
            </gmd:MD_Identifier>
          </gmd:identifier>
          {% endif %}
        </gmd:CI_Citation>
      </gmd:citation>

      <gmd:abstract>
        <gco:CharacterString>{{ abstract }}</gco:CharacterString>
      </gmd:abstract>

      {% if purpose %}
      <gmd:purpose>
        <gco:CharacterString>{{ purpose }}</gco:CharacterString>
      </gmd:purpose>
      {% endif %}

      <gmd:status>
        <gmd:MD_ProgressCode
            codeList="http://www.isotc211.org/2005/resources/Codelist/gmxCodelists.xml#MD_ProgressCode"
            codeListValue="{{ progress }}">{{ progress }}</gmd:MD_ProgressCode>
      </gmd:status>

      <!-- Point of Contact -->
      <gmd:pointOfContact>
        <gmd:CI_ResponsibleParty>
          <gmd:individualName>
            <gco:CharacterString>{{ contact_name }}</gco:CharacterString>
          </gmd:individualName>
          <gmd:organisationName>
            <gco:CharacterString>{{ contact_org }}</gco:CharacterString>
          </gmd:organisationName>
          <gmd:role>
            <gmd:CI_RoleCode
                codeList="http://www.isotc211.org/2005/resources/Codelist/gmxCodelists.xml#CI_RoleCode"
                codeListValue="{{ contact_role }}">{{ contact_role }}</gmd:CI_RoleCode>
          </gmd:role>
        </gmd:CI_ResponsibleParty>
      </gmd:pointOfContact>

      <!-- Keywords: Theme -->
      {% if theme_keywords %}
      <gmd:descriptiveKeywords>
        <gmd:MD_Keywords>
          {% for kw in theme_keywords %}
          <gmd:keyword>
            <gco:CharacterString>{{ kw }}</gco:CharacterString>
          </gmd:keyword>
          {% endfor %}
          <gmd:type>
            <gmd:MD_KeywordTypeCode
                codeList="http://www.isotc211.org/2005/resources/Codelist/gmxCodelists.xml#MD_KeywordTypeCode"
                codeListValue="theme">theme</gmd:MD_KeywordTypeCode>
          </gmd:type>
        </gmd:MD_Keywords>
      </gmd:descriptiveKeywords>
      {% endif %}

      <!-- Keywords: Place -->
      {% if place_keywords %}
      <gmd:descriptiveKeywords>
        <gmd:MD_Keywords>
          {% for kw in place_keywords %}
          <gmd:keyword>
            <gco:CharacterString>{{ kw }}</gco:CharacterString>
          </gmd:keyword>
          {% endfor %}
          <gmd:type>
            <gmd:MD_KeywordTypeCode
                codeList="http://www.isotc211.org/2005/resources/Codelist/gmxCodelists.xml#MD_KeywordTypeCode"
                codeListValue="place">place</gmd:MD_KeywordTypeCode>
          </gmd:type>
        </gmd:MD_Keywords>
      </gmd:descriptiveKeywords>
      {% endif %}

      <!-- Use Constraints / License -->
      {% if license_name %}
      <gmd:resourceConstraints>
        <gmd:MD_LegalConstraints>
          <gmd:useConstraints>
            <gmd:MD_RestrictionCode
                codeList="http://www.isotc211.org/2005/resources/Codelist/gmxCodelists.xml#MD_RestrictionCode"
                codeListValue="otherRestrictions">otherRestrictions</gmd:MD_RestrictionCode>
          </gmd:useConstraints>
          <gmd:otherConstraints>
            <gco:CharacterString>{{ license_name }} ({{ license_url }})</gco:CharacterString>
          </gmd:otherConstraints>
        </gmd:MD_LegalConstraints>
      </gmd:resourceConstraints>
      {% endif %}

      <!-- Language -->
      <gmd:language>
        <gco:CharacterString>{{ language }}</gco:CharacterString>
      </gmd:language>

      <!-- Topic Category -->
      <gmd:topicCategory>
        <gmd:MD_TopicCategoryCode>{{ topic_category }}</gmd:MD_TopicCategoryCode>
      </gmd:topicCategory>

      <!-- Extent -->
      <gmd:extent>
        <gmd:EX_Extent>
          <!-- Geographic -->
          <gmd:geographicElement>
            <gmd:EX_GeographicBoundingBox>
              <gmd:westBoundLongitude>
                <gco:Decimal>{{ west_lon }}</gco:Decimal>
              </gmd:westBoundLongitude>
              <gmd:eastBoundLongitude>
                <gco:Decimal>{{ east_lon }}</gco:Decimal>
              </gmd:eastBoundLongitude>
              <gmd:southBoundLatitude>
                <gco:Decimal>{{ south_lat }}</gco:Decimal>
              </gmd:southBoundLatitude>
              <gmd:northBoundLatitude>
                <gco:Decimal>{{ north_lat }}</gco:Decimal>
              </gmd:northBoundLatitude>
            </gmd:EX_GeographicBoundingBox>
          </gmd:geographicElement>
          <!-- Temporal -->
          {% if temporal_begin and temporal_end %}
          <gmd:temporalElement>
            <gmd:EX_TemporalExtent>
              <gmd:extent>
                <gml:TimePeriod gml:id="timeperiod1">
                  <gml:beginPosition>{{ temporal_begin }}</gml:beginPosition>
                  <gml:endPosition>{{ temporal_end }}</gml:endPosition>
                </gml:TimePeriod>
              </gmd:extent>
            </gmd:EX_TemporalExtent>
          </gmd:temporalElement>
          {% endif %}
        </gmd:EX_Extent>
      </gmd:extent>
    </gmd:MD_DataIdentification>
  </gmd:identificationInfo>

  <!-- ================================================================== -->
  <!-- Distribution Info                                                   -->
  <!-- ================================================================== -->
  <gmd:distributionInfo>
    <gmd:MD_Distribution>
      <gmd:distributionFormat>
        <gmd:MD_Format>
          <gmd:name>
            <gco:CharacterString>CSV</gco:CharacterString>
          </gmd:name>
          <gmd:version>
            <gco:CharacterString>UTF-8</gco:CharacterString>
          </gmd:version>
        </gmd:MD_Format>
      </gmd:distributionFormat>
      <gmd:transferOptions>
        <gmd:MD_DigitalTransferOptions>
          <gmd:onLine>
            <gmd:CI_OnlineResource>
              <gmd:linkage>
                <gmd:URL>{{ distribution_url if distribution_url else 'https://www.ncei.noaa.gov/' }}</gmd:URL>
              </gmd:linkage>
              <gmd:protocol>
                <gco:CharacterString>HTTPS</gco:CharacterString>
              </gmd:protocol>
              <gmd:name>
                <gco:CharacterString>{{ distribution_name if distribution_name else 'Scientific Data Repository' }}</gco:CharacterString>
              </gmd:name>
            </gmd:CI_OnlineResource>
          </gmd:onLine>
        </gmd:MD_DigitalTransferOptions>
      </gmd:transferOptions>
    </gmd:MD_Distribution>
  </gmd:distributionInfo>

  <!-- ================================================================== -->
  <!-- Data Quality / Lineage                                              -->
  <!-- ================================================================== -->
  <gmd:dataQualityInfo>
    <gmd:DQ_DataQuality>
      <gmd:scope>
        <gmd:DQ_Scope>
          <gmd:level>
            <gmd:MD_ScopeCode
                codeList="http://www.isotc211.org/2005/resources/Codelist/gmxCodelists.xml#MD_ScopeCode"
                codeListValue="{{ hierarchy_level }}">{{ hierarchy_level }}</gmd:MD_ScopeCode>
          </gmd:level>
        </gmd:DQ_Scope>
      </gmd:scope>
      <gmd:lineage>
        <gmd:LI_Lineage>
          {% if lineage_statement %}
          <gmd:statement>
            <gco:CharacterString>{{ lineage_statement }}</gco:CharacterString>
          </gmd:statement>
          {% endif %}
          {% for step in process_steps %}
          <gmd:processStep>
            <gmd:LI_ProcessStep>
              <gmd:description>
                <gco:CharacterString>{{ step.description }}</gco:CharacterString>
              </gmd:description>
              {% if step.date_time %}
              <gmd:dateTime>
                <gco:DateTime>{{ step.date_time }}T00:00:00</gco:DateTime>
              </gmd:dateTime>
              {% endif %}
              {% if step.processor %}
              <gmd:processor>
                <gmd:CI_ResponsibleParty>
                  <gmd:organisationName>
                    <gco:CharacterString>{{ step.processor }}</gco:CharacterString>
                  </gmd:organisationName>
                  <gmd:role>
                    <gmd:CI_RoleCode
                        codeList="http://www.isotc211.org/2005/resources/Codelist/gmxCodelists.xml#CI_RoleCode"
                        codeListValue="processor">processor</gmd:CI_RoleCode>
                  </gmd:role>
                </gmd:CI_ResponsibleParty>
              </gmd:processor>
              {% endif %}
            </gmd:LI_ProcessStep>
          </gmd:processStep>
          {% endfor %}
        </gmd:LI_Lineage>
      </gmd:lineage>
    </gmd:DQ_DataQuality>
  </gmd:dataQualityInfo>

  <!-- ================================================================== -->
  <!-- Acquisition Information (ISO 19115-2 extension)                     -->
  <!-- ================================================================== -->
  {% if platform_id or instruments %}
  <gmi:acquisitionInformation>
    <gmi:MI_AcquisitionInformation>
      {% if platform_id %}
      <gmi:platform>
        <gmi:MI_Platform>
          <gmi:identifier>
            <gmd:MD_Identifier>
              <gmd:code>
                <gco:CharacterString>{{ platform_id }}</gco:CharacterString>
              </gmd:code>
            </gmd:MD_Identifier>
          </gmi:identifier>
          <gmi:description>
            <gco:CharacterString>{{ platform_desc }}</gco:CharacterString>
          </gmi:description>
          {% for inst in instruments %}
          <gmi:instrument>
            <gmi:MI_Instrument>
              <gmi:identifier>
                <gmd:MD_Identifier>
                  <gmd:code>
                    <gco:CharacterString>{{ inst.identifier }}</gco:CharacterString>
                  </gmd:code>
                </gmd:MD_Identifier>
              </gmi:identifier>
              <gmi:type>
                <gco:CharacterString>{{ inst.type }}</gco:CharacterString>
              </gmi:type>
              <gmi:description>
                <gco:CharacterString>{{ inst.description }}</gco:CharacterString>
              </gmi:description>
            </gmi:MI_Instrument>
          </gmi:instrument>
          {% endfor %}
        </gmi:MI_Platform>
      </gmi:platform>
      {% endif %}
    </gmi:MI_AcquisitionInformation>
  </gmi:acquisitionInformation>
  {% endif %}

</gmi:MI_Metadata>
